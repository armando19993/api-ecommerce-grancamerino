APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

VITE_APP_NAME="${APP_NAME}"

# Wompi Configuration (Colombia)
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=
WOMPI_INTEGRITY_SECRET=
WOMPI_URL=https://production.wompi.co/v1

# NOWPayments Configuration (Crypto)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_URL=https://api.nowpayments.io/v1

# Frontend URL for redirects
# IMPORTANTE: En desarrollo con localhost, usar http:// NO https://
# Wompi sandbox NO acepta https://localhost, solo http://localhost
FRONTEND_URL=https://ecommerce-grancamerino.vercel.app

# Wompi redirect URL base (el order_id se concatenará automáticamente al final)
# Desarrollo: http://localhost:5173/order-confirmation (sin https)
# Producción: https://ecommerce-grancamerino.vercel.app/order-confirmation
WOMPI_REDIRECT_URL=https://ecommerce-grancamerino.vercel.app/order-confirmation

# Mailjet Configuration
MAILJET_API_KEY=
MAILJET_API_SECRET=
MAILJET_FROM_EMAIL="${MAIL_FROM_ADDRESS}"
MAILJET_FROM_NAME="${MAIL_FROM_NAME}"
